# HOLDPOINT — environment
# Copy to .env (local) or paste into Streamlit Cloud → Settings → Secrets.

# One of these is required. If BOTH are set, GPT-4o is primary and automatically
# fails over to Claude Sonnet on any OpenAI error (revoked key, rate limit, outage).
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: which industry pack loads by default — refining | mining | utilities
# ACTIVE_SITE=refining
